# LLM API配置（规划、模拟、报告、聊天）
# 推荐使用 OpenRouter 的 OpenAI 兼容接口
LLM_API_KEY=your_openrouter_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=qwen/qwen3.6-plus:free

# ===== Sports 研究配置（仅用于信息检索，推荐使用 Perplexity Sonar）=====
SPORTS_RESEARCH_API_KEY=your_perplexity_api_key_here
SPORTS_RESEARCH_BASE_URL=https://api.perplexity.ai
SPORTS_RESEARCH_MODEL_NAME=sonar-pro

# ===== Flask 生产环境配置 =====
SECRET_KEY=replace_with_a_long_random_secret
FLASK_DEBUG=False

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Sports public data configuration（可选，已不作为主路径）=====
SPORTS_DATA_BASE_URL=
SPORTS_DATA_API_KEY=

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

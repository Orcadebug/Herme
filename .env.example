# LLM API Configuration (planning, simulation, reporting, chat)
# Recommended to use OpenRouter's OpenAI-compatible interface
LLM_API_KEY=your_openrouter_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=qwen/qwen3.6-plus:free

# ===== Sports Research Configuration (for information retrieval only, recommended: Perplexity Sonar) =====
SPORTS_RESEARCH_API_KEY=your_perplexity_api_key_here
SPORTS_RESEARCH_BASE_URL=https://api.perplexity.ai
SPORTS_RESEARCH_MODEL_NAME=sonar-pro

# ===== Flask Production Configuration =====
SECRET_KEY=replace_with_a_long_random_secret
FLASK_DEBUG=False

# ===== ZEP Memory Graph Configuration =====
# Monthly free quota is enough for basic usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Sports public data configuration (optional, no longer the primary path) =====
SPORTS_DATA_BASE_URL=
SPORTS_DATA_API_KEY=

# ===== LLM Acceleration Configuration (optional) =====
# Note: If not using acceleration configuration, do not include the following config items in the env file
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
